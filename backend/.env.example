# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/educurator

# ── JWT ────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-secret-key-in-production

# ── LLM (al menos una de las siguientes) ──────────────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-...
# O Google Gemini
GEMINI_API_KEY=
# O Hugging Face local
HUGGINGFACE_MODEL=

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# ── Langfuse (opcional — tracing y observabilidad) ────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── LangGraph checkpoint ───────────────────────────────────────────────────────
AGENT_CHECKPOINT_DB_PATH=data/checkpoints/curation_graph.sqlite

# ── Redundancia ────────────────────────────────────────────────────────────────
REDUNDANCY_THRESHOLD=0.90

# ── Web Search ────────────────────────────────────────────────────────────────
# Proveedor: "tavily" (requiere API key) o "duckduckgo" (sin API key, default)
WEB_SEARCH_PROVIDER=duckduckgo
# API key de Tavily (solo necesaria si WEB_SEARCH_PROVIDER=tavily)
TAVILY_API_KEY=
# Resultados máximos por consulta
WEB_SEARCH_MAX_RESULTS=5
# Timeout en segundos por consulta
WEB_SEARCH_TIMEOUT=10
